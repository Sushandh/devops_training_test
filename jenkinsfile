pipeline{
agent any{
stages{
stage("create build SCM"){
steps{
script{
sh 'mkdir -p scm'
writeFile file: 'scm/testfile.txt', text: 'hi testfile has been executed '
writeFile file: 'scm/testfiles.md', text: 'hi testfiles has been executed'
}
}
}
stage("Archieve build SCM"){
steps {
archiveArtifacts artifacts: 'scm/*.txt', excludes: 'scm/*.md', followSymlinks: false
input 'Do i need to continue '
}
}
}
}
}
